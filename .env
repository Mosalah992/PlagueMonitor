# Epidemic Lab — Simulation Configuration
# Guardian/Analyst use llama3.2, Courier uses dolphin-mistral (uncensored)

# LLM Models
AGENT_A_MODEL=llama3.2:latest
AGENT_B_MODEL=llama3.2:latest
AGENT_C_MODEL=llama3.2:latest
AGENT_C_ATTACK_MODEL=dolphin-mistral:latest

# LLM Global Settings
LLM_ENABLED=1
# Local Ollama inference on GTX 1660 Ti is exceeding 60s for llama3.2 in this stack.
# Keep timeout above observed steady-state latency to avoid forced fallback mode.
LLM_TIMEOUT_S=180

# Agent A (Guardian) — High Security (hardened thresholds)
AGENT_A_DEFENSE_LEVEL=0.85
GUARDIAN_MAX_INFECTION_P=0.15
GUARDIAN_HARD_BLOCK_CONFIDENCE=0.60
GUARDIAN_SUSPICION_WINDOW=5
GUARDIAN_SUSPICION_THRESHOLD=3
GUARDIAN_IMMUNITY_BOOST_ON_BLOCK=0.04
AGENT_A_LLM_TEMPERATURE=0.2

# Agent B (Analyst) — Medium Security
AGENT_B_DEFENSE_LEVEL=0.50
LLM_COMPLIANCE_WEIGHT=0.25
ANALYST_MAX_DEFENSE_REDUCTION=0.25
ANALYST_MAX_DEFENSE_BOOST=0.20
ANALYST_MIN_INFECTION_P=0.15
ANALYST_MAX_INFECTION_P=0.85
AGENT_B_LLM_TEMPERATURE=0.35

# Agent C (Courier) — Attacker (uncensored model for payload generation)
USE_LLM_PAYLOADS=1
LLM_ATTACK_BOOST=1.15
AGENT_C_LLM_TEMPERATURE=0.7
ATTACKER_OBJECTIVE=SPREAD_FAST
ATTACKER_LOCK_OBJECTIVE=0
ATTACKER_SEED=1337
ATTACKER_DEBUG=0
ATTACK_GENERATION_MAX_RETRIES=2

# Timing — longer heartbeats for multi-hour simulation
HEARTBEAT_INTERVAL_S=3600

# C2 post-compromise containment
# Run 07 showed: beacon 91% success, task 95%, exfil 85% — all too permissive.
# Raised block rates and added session TTL + beacon cap to reduce post-foothold budget.
C2_BEACON_BLOCK_PROB=0.35
C2_TASK_BLOCK_PROB=0.30
C2_EXFIL_BLOCK_PROB=0.45
# Max wall-clock seconds a C2 session stays active before auto-expiry
C2_SESSION_TTL_S=300
# Max beacons per session before the channel is considered burned
C2_MAX_BEACONS_PER_SESSION=8

# LLM verdict cache — skip repeated LLM calls for payloads seen in the last N seconds.
# Run 07 top payload (41df7b01418f) was replayed 1260 times; caching kills redundant 144s calls.
LLM_VERDICT_CACHE_TTL_S=300

C2_BEACON_SERVER_URL=https://v0-beaconing-project-server-mdml8734h-mosalah992s-projects.vercel.app
# Vercel Deployment Protection bypass — get from Vercel Dashboard → Settings → Deployment Protection
VERCEL_PROTECTION_BYPASS=
